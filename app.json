{
  "expo": {
    "name": "Sans Company",
    "slug": "sans-club",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/sansicon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/sansicon.png",
          "color": "#6200EA",
          "defaultChannel": "default"
        }
      ]
    ],
    "notification": {
      "icon": "./assets/sansicon.png",
      "color": "#6200EA",
      "androidMode": "default",
      "androidCollapsedTitle": "Sans Company"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sansclub.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.sansclub.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6200EA"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "WAKE_LOCK"
      ],
      "useNextNotificationsApi": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "f5314f8e-8e80-4340-9541-b7b9cdd36d18"
      }
    }
  }
}